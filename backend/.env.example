# Backend environment (Render)
# Do NOT commit real secrets. Copy to Render Environment Variables.

NODE_ENV=production
PORT=4000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=<generate_a_long_random_secret>

# Frontend URL (Vercel) used for invite links
FRONTEND_URL=https://<your-vercel-domain>

# CORS origin (Vercel) used for REST + WebSockets
CORS_ORIGIN=https://<your-vercel-domain>

# Email (SendGrid)
ENABLE_EMAIL=true
SENDGRID_API_KEY=<sendgrid_api_key>
EMAIL_FROM=noreply@<yourdomain>

# Production Environment Configuration

# Server Port
PORT=4000

# MongoDB URI (REQUIRED in production)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/affiliate
MONGO_URI=

# Use In-Memory DB (Set to 'false' or leave empty in production)
USE_IN_MEMORY_DB=false

# JWT Secret (REQUIRED - Change to a long random string)
JWT_SECRET=

# Node Environment
NODE_ENV=production

# CORS Origin (Set to your frontend domain)
# Example: https://affiliate.example.com
CORS_ORIGIN=*

# Feature Toggles
MOCK_PAYMENTS=false
DETAILED_LOGGING=false
ENABLE_EMAIL=true
